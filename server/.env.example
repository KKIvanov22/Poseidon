ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080

# Public base URL of this API (used by clients to build request URLs)
API_BASE_URL=http://localhost:8080

# CORS allowed origins — add as many as needed (0-indexed)
# Supports any origin that will call the API from a browser (web clients only;
# native mobile clients such as Flutter do not require CORS entries).
CORS_ORIGIN_0=http://localhost:3000
CORS_ORIGIN_1=http://localhost:3001
# CORS_ORIGIN_2=https://your-production-domain.com

POSTGRES_DB=poseidon
POSTGRES_HOST=
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=
POSTGRES_APP_USER=
POSTGRES_APP_PASSWORD=
POSTGRES_PORT=56204
POSTGRES_SSL_MODE=Prefer
POSTGRES_TRUST_SERVER_CERTIFICATE=false

# Optional single-URL alternative. postgres:// and postgresql:// URLs are
# normalized by the server into the Npgsql connection string format.
# DATABASE_URL=

RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=...
RABBITMQ_VHOST=
RABBITMQ_TLS=false
RABBITMQ_TLS_SERVER_NAME=

MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
RABBITMQ_DEV_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Firebase Cloud Messaging for Android push notifications.
# For hosting platforms that cannot upload files, set the individual service
# account fields below. Keep FIREBASE_CLOUD_MESSAGING_PRIVATE_KEY on one line
# with \n between PEM lines.
FIREBASE_CLOUD_MESSAGING_ENABLED=false
FIREBASE_CLOUD_MESSAGING_PROJECT_ID=
FIREBASE_CLOUD_MESSAGING_PRIVATE_KEY_ID=
FIREBASE_CLOUD_MESSAGING_PRIVATE_KEY=
FIREBASE_CLOUD_MESSAGING_CLIENT_EMAIL=
FIREBASE_CLOUD_MESSAGING_CLIENT_ID=
FIREBASE_CLOUD_MESSAGING_CLIENT_X509_CERT_URL=

# Optional alternatives: provide the full service-account JSON, or use a file
# path / GOOGLE_APPLICATION_CREDENTIALS for local development.
FIREBASE_CLOUD_MESSAGING_CREDENTIAL_JSON=
FIREBASE_CLOUD_MESSAGING_CREDENTIAL_PATH=
