{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=poseidon;Username=poseidon_app;Password=poseidon_app_dev_password"
  },
  "Jwt": {
    "Issuer": "Poseidon",
    "Audience": "Poseidon",
    "SigningKey": "replace-this-development-key-with-a-secret-at-least-32-bytes",
    "ExpirationMinutes": 60
  },
  "RabbitMq": {
    "Enabled": true,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "",
    "Password": "",
    "VirtualHost": "/",
    "RequireTls": false,
    "TlsServerName": "",
    "ExchangeName": "poseidon.notifications",
    "QueueName": "poseidon.notifications.email",
    "RoutingKey": "notifications.email",
    "PublisherPollIntervalSeconds": 5,
    "PublisherBatchSize": 25,
    "PublisherLeaseSeconds": 60,
    "ConsumerPrefetchCount": 1,
    "MaxDeliveryAttempts": 5
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "FromEmail": "no-reply@poseidon.com",
    "FromName": "Poseidon Events System"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Firebase": {
    "CloudMessaging": {
      "Enabled": false,
      "ProjectId": "",
      "CredentialPath": "",
      "CredentialJson": "",
      "PrivateKeyId": "",
      "PrivateKey": "",
      "ClientEmail": "",
      "ClientId": "",
      "ClientX509CertUrl": ""
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001"
    ]
  },
  "AllowedHosts": "*"
}
